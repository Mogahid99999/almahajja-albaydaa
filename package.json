{
  "name": "riwaq-al-ilm",
  "version": "1.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:contract": "jest --config jest.contract.config.js",
    "doctor": "npx expo-doctor",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/amiri": "^0.4.1",
    "@expo-google-fonts/ibm-plex-sans-arabic": "^0.4.2",
    "@expo/metro-runtime": "~56.0.15",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "babel-preset-expo": "~56.0.0",
    "client-zip": "^2.5.0",
    "expo": "~56.0.14",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.15",
    "expo-network": "~56.0.5",
    "expo-notifications": "~56.0.19",
    "expo-router": "~56.2.13",
    "expo-splash-screen": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "fflate": "^0.8.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~3.0.2",
    "react-native-reanimated": "4.3.1",
    "react-native-restart": "^0.0.28",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@supabase/supabase-js": "^2.110.7",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.0",
    "patch-package": "^8.0.1",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "//": "react-native-restart powers the one-time iOS RTL restart fallback (app/_layout.tsx); it works on the new architecture via RCTReloadCommand but the directory hasn't marked it tested.",
        "exclude": [
          "react-native-restart"
        ]
      }
    },
    "autolinking": {
      "//": "expo-audio is patched (media notification prev/next, deep-link, duration) — build it from source so node_modules edits/patch-package apply instead of the prebuilt AAR.",
      "buildFromSource": [
        "expo-audio"
      ]
    }
  },
  "private": true
}
