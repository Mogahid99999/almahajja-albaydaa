# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# secrets — Firebase Admin SDK service-account key (full project access; never commit)
*firebase-adminsdk*.json

# supabase CLI local cache/state
supabase/.temp/

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Original audio file copies (sample-lecture.mp3 in assets/ is the canonical copy)
Voice 015*
assets/Voice 015*

# Large local test recordings — keep big media OUT of the project root. A 50MB+
# file in the Metro-watched tree slows the web dev server's cold start, which can
# trip expo-font's 12s fontfaceobserver timeout (→ boxed icons). Pick test files
# from anywhere via the upload dialog; they don't need to live in the repo.
/record.ogg
/*.ogg
/test-media/

# Native module build artifacts (Gradle output — regenerated on build)
modules/*/android/build/
modules/*/ios/build/
modules/*/build/

# Landing/download page — fully independent Astro project, deployed separately
landing/

# Landing/download page v2 — plain HTML/CSS/JS, fully independent, deployed separately
landing2/
